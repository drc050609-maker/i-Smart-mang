# Supabase — Project Settings → API
# Next.js loads `.env.local` for `next dev` / `next build`.

# Client (safe to prefix with NEXT_PUBLIC)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy anon JWT (optional fallback for seed scripts)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: service role secret (never commit, never use in Client Components).
# Required for `npm run seed` — bypasses RLS for trusted scripts only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Legacy (unused by this app)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
